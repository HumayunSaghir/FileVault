<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Download</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%233d52ff'/><path d='M8 10c0-1.1.9-2 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H10a2 2 0 0 1-2-2V10z' fill='white'/></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:             #0e0f13;
            --surface:        #16181f;
            --border:         #2a2d38;
            --blue:           #3d52ff;
            --blue-glow:      rgba(61,82,255,0.25);
            --blue-dim:       rgba(61,82,255,0.12);
            --white:          #f0f1f5;
            --muted:          #6b7080;
            --success:        #22c55e;
            --success-dim:    rgba(34,197,94,0.12);
            --success-border: rgba(34,197,94,0.35);
            --error:          #ef4444;
            --error-dim:      rgba(239,68,68,0.12);
            --error-border:   rgba(239,68,68,0.35);
        }

        html, body { height: 100%; background: var(--bg); color: var(--white); font-family: 'Inter', sans-serif; }

        body::before {
            content: ''; position: fixed; inset: 0;
            background-image: linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 48px 48px; opacity: 0.35; pointer-events: none; z-index: 0;
        }
        body::after {
            content: ''; position: fixed; top: -120px; left: -120px; width: 520px; height: 520px;
            background: radial-gradient(circle, var(--blue-glow) 0%, transparent 70%); pointer-events: none; z-index: 0;
        }

        /* ── toast ── */
        .toast { position: fixed; top: 16px; left: 50%; transform: translateX(-50%) translateY(-12px); z-index: 9999; display: flex; align-items: center; gap: 10px; padding: 11px 16px; border-radius: 10px; font-family: 'Geist', sans-serif; font-size: 0.85rem; font-weight: 500; backdrop-filter: blur(12px); box-shadow: 0 8px 32px rgba(0,0,0,0.4); opacity: 0; animation: toastIn .35s ease forwards, toastOut .35s ease 4s forwards; max-width: calc(100vw - 32px); white-space: normal; word-break: break-word; }
        .toast.success { background: var(--success-dim); border: 1px solid var(--success-border); color: #86efac; }
        .toast.error   { background: var(--error-dim);   border: 1px solid var(--error-border);   color: #fca5a5; }
        .toast-icon { width: 18px; height: 18px; border-radius: 50%; display: grid; place-items: center; flex-shrink: 0; }
        .toast.success .toast-icon { background: var(--success); }
        .toast.error   .toast-icon { background: var(--error); }
        .toast-icon svg { width: 10px; height: 10px; stroke: #fff; fill: none; stroke-width: 2.5; }
        .toast-close { margin-left: 8px; cursor: pointer; opacity: 0.6; transition: opacity .15s; background: none; border: none; color: inherit; padding: 4px; line-height: 1; flex-shrink: 0; }
        .toast-close:hover { opacity: 1; }
        .toast-close svg { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2; }
        @keyframes toastIn  { from { opacity: 0; transform: translateX(-50%) translateY(-12px); } to { opacity: 1; transform: translateX(-50%) translateY(0); } }
        @keyframes toastOut { from { opacity: 1; transform: translateX(-50%) translateY(0); } to { opacity: 0; transform: translateX(-50%) translateY(-12px); } }

        /* ── nav ── */
        nav { position: relative; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 0 48px; height: 68px; border-bottom: 1px solid var(--border); backdrop-filter: blur(10px); background: rgba(14,15,19,0.9); }
        .nav-logo { display: flex; align-items: center; gap: 10px; font-family: 'Geist', sans-serif; font-weight: 800; font-size: 1.2rem; color: var(--white); text-decoration: none; }
        .nav-logo-icon { width: 34px; height: 34px; background: var(--blue); border-radius: 8px; display: grid; place-items: center; flex-shrink: 0; }
        .nav-logo-icon svg { width: 18px; height: 18px; fill: #fff; }
        .nav-links { display: flex; gap: 36px; list-style: none; }
        .nav-links a { font-size: 0.9rem; color: var(--muted); text-decoration: none; transition: color .2s; }
        .nav-links a:hover, .nav-links a.active { color: var(--white); }
        .nav-cta { padding: 8px 22px; border: 1px solid var(--border); border-radius: 6px; color: var(--white); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: border-color .2s, background .2s; white-space: nowrap; }
        .nav-cta:hover { border-color: var(--blue); background: var(--blue-dim); }
        .nav-hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; background: none; border: none; }
        .nav-hamburger span { display: block; width: 22px; height: 2px; background: var(--white); border-radius: 2px; transition: all .25s; }
        .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
        .nav-hamburger.open span:nth-child(2) { opacity: 0; }
        .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
        .nav-mobile-menu { display: none; position: fixed; top: 68px; left: 0; right: 0; background: rgba(14,15,19,0.98); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); z-index: 99; padding: 20px 24px; flex-direction: column; gap: 4px; }
        .nav-mobile-menu.open { display: flex; }
        .nav-mobile-menu a { color: var(--muted); text-decoration: none; font-size: 1rem; padding: 12px 0; border-bottom: 1px solid var(--border); transition: color .2s; }
        .nav-mobile-menu a:last-child { border-bottom: none; }
        .nav-mobile-menu a:hover, .nav-mobile-menu a.active { color: var(--white); }
        .nav-mobile-cta { margin-top: 8px; padding: 12px; background: var(--blue); color: #fff !important; border-radius: 8px; text-align: center; font-weight: 600; border-bottom: none !important; }

        /* ── main ── */
        main { position: relative; z-index: 1; min-height: calc(100vh - 68px - 65px); display: flex; align-items: center; justify-content: center; padding: clamp(32px, 6vw, 60px) clamp(16px, 4vw, 48px); }

        .download-wrapper { width: 100%; max-width: 560px; animation: fadeUp .5s ease both; }
        .download-badge { display: inline-flex; align-items: center; gap: 8px; background: var(--blue-dim); border: 1px solid rgba(61,82,255,0.3); border-radius: 99px; padding: 5px 14px; font-size: 0.75rem; color: #8b9bff; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 20px; }
        .download-badge span { width: 6px; height: 6px; background: var(--blue); border-radius: 50%; flex-shrink: 0; }
        .download-heading { font-family: 'Geist', sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 800; letter-spacing: -0.02em; margin-bottom: 8px; }
        .download-sub { font-size: clamp(0.82rem, 2vw, 0.9rem); color: var(--muted); margin-bottom: 32px; line-height: 1.6; }
        .download-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: clamp(20px, 4vw, 36px); }

        .field { display: flex; flex-direction: column; gap: 8px; margin-bottom: 24px; }
        .field label { font-size: 0.825rem; font-weight: 500; color: var(--white); letter-spacing: 0.02em; }
        .input-wrap { position: relative; display: flex; align-items: center; }
        .input-wrap svg { position: absolute; left: 14px; width: 16px; height: 16px; stroke: var(--muted); fill: none; stroke-width: 1.8; pointer-events: none; transition: stroke .2s; }
        .input-wrap input[type="text"] { width: 100%; padding: 13px 14px 13px 42px; background: var(--bg); border: 1px solid var(--border); border-radius: 10px; color: var(--white); font-family: 'Courier New', monospace; font-size: 0.9rem; letter-spacing: 0.04em; outline: none; transition: border-color .2s, box-shadow .2s; }
        .input-wrap input[type="text"]::placeholder { color: var(--muted); font-family: 'Inter', sans-serif; letter-spacing: 0; font-size: 0.875rem; }
        .input-wrap input[type="text"]:focus { border-color: var(--blue); box-shadow: 0 0 0 3px var(--blue-dim); }
        .input-wrap:focus-within svg { stroke: var(--blue); }
        .field-hint { font-size: 0.775rem; color: var(--muted); display: flex; align-items: center; gap: 5px; flex-wrap: wrap; }
        .field-hint svg { width: 12px; height: 12px; stroke: var(--muted); fill: none; stroke-width: 2; flex-shrink: 0; }

        .btn-download { width: 100%; padding: 14px; background: var(--blue); color: #fff; border: none; border-radius: 10px; font-family: 'Geist', sans-serif; font-size: 0.95rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: opacity .2s, transform .15s, box-shadow .2s; }
        .btn-download:hover { opacity: 0.88; transform: translateY(-1px); box-shadow: 0 8px 28px var(--blue-glow); }
        .btn-download:active { transform: translateY(0); }
        .btn-download svg { width: 16px; height: 16px; stroke: #fff; fill: none; stroke-width: 2; flex-shrink: 0; }

        .divider { display: flex; align-items: center; gap: 12px; margin: 24px 0; color: var(--muted); font-size: 0.75rem; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

        .info-box { background: var(--blue-dim); border: 1px solid rgba(61,82,255,0.2); border-radius: 10px; padding: 14px 16px; display: flex; gap: 12px; align-items: flex-start; }
        .info-box svg { width: 16px; height: 16px; stroke: #8b9bff; fill: none; stroke-width: 2; flex-shrink: 0; margin-top: 1px; }
        .info-box p { font-size: 0.8rem; color: #8b9bff; line-height: 1.55; }
        .info-box strong { color: var(--white); font-weight: 500; }

        .back-link { display: inline-flex; align-items: center; gap: 6px; margin-top: 20px; font-size: 0.825rem; color: var(--muted); text-decoration: none; transition: color .2s; }
        .back-link:hover { color: var(--white); }
        .back-link svg { width: 13px; height: 13px; stroke: currentColor; fill: none; stroke-width: 2; }

        footer { position: relative; z-index: 1; border-top: 1px solid var(--border); padding: clamp(16px, 2.5vw, 22px) clamp(16px, 4vw, 48px); display: flex; align-items: center; justify-content: space-between; font-size: clamp(0.72rem, 1.5vw, 0.8rem); color: var(--muted); flex-wrap: wrap; gap: 12px; }
        footer a { color: var(--muted); text-decoration: none; transition: color .2s; }
        footer a:hover { color: var(--white); }
        .footer-right { display: flex; gap: clamp(14px, 3vw, 24px); align-items: center; flex-wrap: wrap; }
        .footer-email { display: flex; align-items: center; gap: 6px; }
        .footer-email svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 1.8; }
        @media (max-width: 360px) { .footer-email-text { display: none; } }

        @keyframes fadeUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }

        /* ── RESPONSIVE ── */
        @media (max-width: 768px) {
            .nav-links, .nav-cta { display: none; }
            .nav-hamburger { display: flex; }
            main { align-items: flex-start; }
            .input-wrap input[type="text"] { font-size: 0.8rem; }
            footer { flex-direction: column; align-items: flex-start; }
        }
        @media (max-width: 400px) {
            .nav-logo span { display: none; }
            .input-wrap input[type="text"] { padding: 11px 12px 11px 38px; font-size: 0.75rem; }
        }
    </style>
</head>
<body>

    <% if (locals.message) { %>
        <% const isError = locals.message.toLowerCase().includes('error') || locals.message.toLowerCase().includes('fail') || locals.message.toLowerCase().includes('invalid') || locals.message.toLowerCase().includes('not ') || !locals.message.toLowerCase().includes('found'); %>
        <% const toastType = isError ? 'error' : 'success'; %>
        <div class="toast <%= toastType %>" id="toast">
            <div class="toast-icon">
                <% if (toastType === 'success') { %><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                <% } else { %><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg><% } %>
            </div>
            <%= locals.message %>
            <button class="toast-close" onclick="dismissToast()"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        </div>
    <% } %>

    <nav>
        <a href="/" class="nav-logo">
            <div class="nav-logo-icon"><svg viewBox="0 0 24 24"><path d="M3 7c0-1.1.9-2 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/></svg></div>
            <span>FileVault</span>
        </a>
        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/upload">Upload</a></li>
            <li><a href="/download" class="active">Download</a></li>
        </ul>
        <a href="/upload" class="nav-cta">Get Started</a>
        <button class="nav-hamburger" id="hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </nav>

    <div class="nav-mobile-menu" id="mobileMenu">
        <a href="/">Home</a>
        <a href="/upload">Upload</a>
        <a href="/download" class="active">Download</a>
        <a href="/upload" class="nav-mobile-cta">Get Started</a>
    </div>

    <main>
        <div class="download-wrapper">
            <div class="download-badge"><span></span> Download File</div>
            <h1 class="download-heading">Find your file</h1>
            <p class="download-sub">Enter the unique ID you received after uploading to instantly retrieve and download your file.</p>

            <div class="download-card">
                <form action="/download" method="post">
                    <div class="field">
                        <label for="fileId">File ID</label>
                        <div class="input-wrap">
                            <input type="text" name="id" id="fileId" placeholder="Paste your file ID here" autocomplete="off" spellcheck="false">
                            <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        </div>
                        <span class="field-hint">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            You can find this ID on the home page after uploading a file
                        </span>
                    </div>

                    <button type="submit" class="btn-download">
                        <svg viewBox="0 0 24 24"><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/></svg>
                        Download File
                    </button>

                    <div class="divider">or</div>

                    <div class="info-box">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        <p>Don't have an ID yet? <strong><a href="/upload" style="color:var(--white);text-decoration:none;">Upload a file first</a></strong> and you'll receive a unique ID on the home page.</p>
                    </div>
                </form>
            </div>

            <a href="/" class="back-link">
                <svg viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Back to Home
            </a>
        </div>
    </main>

    <footer>
        <span>Created by <a href="https://github.com/HumayunSaghir" target="_blank">Humayun Saghir</a></span>
        <div class="footer-right">
            <a href="mailto:hr32967262@gmail.com" class="footer-email">
                <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <span class="footer-email-text">hr32967262@gmail.com</span>
            </a>
            <a href="https://github.com/HumayunSaghir" target="_blank">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            </a>
        </div>
    </footer>

    <script>
        const hamburger  = document.getElementById('hamburger');
        const mobileMenu = document.getElementById('mobileMenu');
        hamburger.addEventListener('click', () => { hamburger.classList.toggle('open'); mobileMenu.classList.toggle('open'); });
        mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => { hamburger.classList.remove('open'); mobileMenu.classList.remove('open'); }));

        function dismissToast() {
            const t = document.getElementById('toast');
            if (t) { t.style.animation = 'toastOut .35s ease forwards'; setTimeout(() => t.remove(), 350); }
        }
        const toast = document.getElementById('toast');
        if (toast) setTimeout(() => toast.remove(), 4700);
    </script>
</body>
</html>