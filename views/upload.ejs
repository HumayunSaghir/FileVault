<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload</title>

    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%233d52ff'/><path d='M8 10c0-1.1.9-2 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H10a2 2 0 0 1-2-2V10z' fill='white'/></svg>">

    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:        #0e0f13;
            --surface:   #16181f;
            --border:    #2a2d38;
            --blue:      #3d52ff;
            --blue-glow: rgba(61,82,255,0.25);
            --blue-dim:  rgba(61,82,255,0.12);
            --white:     #f0f1f5;
            --muted:     #6b7080;
            --success:        #22c55e;
            --success-dim:    rgba(34,197,94,0.12);
            --success-border: rgba(34,197,94,0.35);
            --error:          #ef4444;
            --error-dim:      rgba(239,68,68,0.12);
            --error-border:   rgba(239,68,68,0.35);
        }

        html, body {
            height: 100%;
            background: var(--bg);
            color: var(--white);
            font-family: 'Inter', sans-serif;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 48px 48px;
            opacity: 0.35;
            pointer-events: none;
            z-index: 0;
        }

        body::after {
            content: '';
            position: fixed;
            top: -120px; left: -120px;
            width: 520px; height: 520px;
            background: radial-gradient(circle, var(--blue-glow) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        /* ── Upload Loading Overlay ── */
        .upload-overlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(14, 15, 19, 0.92);
            backdrop-filter: blur(16px);
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 28px;
            animation: overlayIn .3s ease both;
        }

        .upload-overlay.visible {
            display: flex;
        }

        @keyframes overlayIn {
            from { opacity: 0; }
            to   { opacity: 1; }
        }

        /* Circular spinner */
        .spinner-ring {
            position: relative;
            width: 80px;
            height: 80px;
        }

        .spinner-ring svg {
            width: 80px;
            height: 80px;
            transform: rotate(-90deg);
        }

        .spinner-track {
            fill: none;
            stroke: var(--border);
            stroke-width: 4;
        }

        .spinner-arc {
            fill: none;
            stroke: var(--blue);
            stroke-width: 4;
            stroke-linecap: round;
            stroke-dasharray: 188;
            stroke-dashoffset: 188;
            animation: spinArc 1.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
            filter: drop-shadow(0 0 6px rgba(61,82,255,0.6));
        }

        @keyframes spinArc {
            0%   { stroke-dashoffset: 188; transform-origin: center; }
            50%  { stroke-dashoffset: 47; }
            100% { stroke-dashoffset: 188; transform-origin: center; }
        }

        /* Spinning wrapper for continuous rotation */
        .spinner-rotate {
            animation: rotateFull 1.6s linear infinite;
            transform-origin: center;
        }

        @keyframes rotateFull {
            from { transform: rotate(0deg); }
            to   { transform: rotate(360deg); }
        }

        /* Inner icon */
        .spinner-inner {
            position: absolute;
            inset: 0;
            display: grid;
            place-items: center;
        }

        .spinner-inner svg {
            width: 26px;
            height: 26px;
            stroke: var(--blue);
            fill: none;
            stroke-width: 1.8;
            animation: pulseIcon 1.6s ease-in-out infinite;
        }

        @keyframes pulseIcon {
            0%, 100% { opacity: 0.5; transform: scale(0.9); }
            50%       { opacity: 1;   transform: scale(1.05); }
        }

        .upload-overlay-title {
            font-family: 'Geist', sans-serif;
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--white);
            letter-spacing: -0.01em;
        }

        .upload-overlay-sub {
            font-size: 0.82rem;
            color: var(--muted);
            margin-top: -18px;
        }

        /* Progress dots */
        .upload-dots {
            display: flex;
            gap: 6px;
        }

        .upload-dots span {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--blue);
            opacity: 0.3;
            animation: dotBlink 1.4s ease-in-out infinite;
        }

        .upload-dots span:nth-child(2) { animation-delay: .2s; }
        .upload-dots span:nth-child(3) { animation-delay: .4s; }

        @keyframes dotBlink {
            0%, 80%, 100% { opacity: 0.3; transform: scale(1); }
            40%            { opacity: 1;   transform: scale(1.4); }
        }

        /* ── toast popup ── */
        .toast {
            position: fixed;
            top: 24px;
            left: 50%;
            transform: translateX(-50%) translateY(-12px);
            z-index: 999;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 20px;
            border-radius: 10px;
            font-family: 'Geist', sans-serif;
            font-size: 0.875rem;
            font-weight: 500;
            backdrop-filter: blur(12px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            opacity: 0;
            animation: toastIn .35s ease forwards, toastOut .35s ease 4s forwards;
            white-space: nowrap;
            max-width: 90vw;
        }

        .toast.success {
            background: var(--success-dim);
            border: 1px solid var(--success-border);
            color: #86efac;
        }

        .toast.error {
            background: var(--error-dim);
            border: 1px solid var(--error-border);
            color: #fca5a5;
        }

        .toast-icon {
            width: 18px; height: 18px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            flex-shrink: 0;
        }

        .toast.success .toast-icon { background: var(--success); }
        .toast.error   .toast-icon { background: var(--error); }

        .toast-icon svg { width: 10px; height: 10px; stroke: #fff; fill: none; stroke-width: 2.5; }

        .toast-close {
            margin-left: 12px;
            cursor: pointer;
            opacity: 0.6;
            transition: opacity .15s;
            background: none;
            border: none;
            color: inherit;
            padding: 0;
            line-height: 1;
        }
        .toast-close:hover { opacity: 1; }
        .toast-close svg { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2; }

        @keyframes toastIn {
            from { opacity: 0; transform: translateX(-50%) translateY(-12px); }
            to   { opacity: 1; transform: translateX(-50%) translateY(0); }
        }

        @keyframes toastOut {
            from { opacity: 1; transform: translateX(-50%) translateY(0); }
            to   { opacity: 0; transform: translateX(-50%) translateY(-12px); }
        }

        /* ── navbar ── */
        nav {
            position: relative;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 clamp(16px, 4vw, 48px);
            height: 68px;
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(10px);
            background: rgba(14,15,19,0.9);
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-family: 'Geist', sans-serif;
            font-weight: 800;
            font-size: clamp(1rem, 2.5vw, 1.2rem);
            color: var(--white);
            text-decoration: none;
            flex-shrink: 0;
        }

        .nav-logo-icon {
            width: 34px; height: 34px;
            background: var(--blue);
            border-radius: 8px;
            display: grid;
            place-items: center;
            flex-shrink: 0;
        }

        .nav-logo-icon svg { width: 18px; height: 18px; fill: #fff; }

        .nav-links {
            display: flex;
            gap: clamp(16px, 3vw, 36px);
            list-style: none;
        }

        .nav-links a {
            font-size: clamp(0.8rem, 1.5vw, 0.9rem);
            color: var(--muted);
            text-decoration: none;
            transition: color .2s;
            white-space: nowrap;
        }

        .nav-links a:hover { color: var(--white); }
        .nav-links a.active { color: var(--white); }

        .nav-cta {
            padding: 8px clamp(12px, 2vw, 22px);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--white);
            text-decoration: none;
            font-size: clamp(0.78rem, 1.5vw, 0.875rem);
            font-weight: 500;
            transition: border-color .2s, background .2s;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .nav-cta:hover { border-color: var(--blue); background: var(--blue-dim); }

        /* hamburger */
        .nav-hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; background: none; border: none; }
        .nav-hamburger span { display: block; width: 22px; height: 2px; background: var(--white); border-radius: 2px; transition: all .25s; }
        .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
        .nav-hamburger.open span:nth-child(2) { opacity: 0; }
        .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

        .nav-mobile-menu {
            display: none; position: fixed; top: 68px; left: 0; right: 0;
            background: rgba(14,15,19,0.98); backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border); z-index: 99;
            padding: 20px 24px; flex-direction: column; gap: 4px;
        }
        .nav-mobile-menu.open { display: flex; }
        .nav-mobile-menu a { color: var(--muted); text-decoration: none; font-size: 1rem; padding: 12px 0; border-bottom: 1px solid var(--border); transition: color .2s; }
        .nav-mobile-menu a:last-child { border-bottom: none; }
        .nav-mobile-menu a:hover, .nav-mobile-menu a.active { color: var(--white); }
        .nav-mobile-cta { margin-top: 8px; padding: 12px; background: var(--blue); color: #fff !important; border-radius: 8px; text-align: center; font-weight: 600; border-bottom: none !important; }

        @media (max-width: 768px) {
            .nav-links, .nav-cta { display: none; }
            .nav-hamburger { display: flex; }
        }

        /* ── main ── */
        main {
            position: relative;
            z-index: 1;
            min-height: calc(100vh - 68px - 65px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: clamp(32px, 6vw, 60px) clamp(16px, 4vw, 48px);
        }

        /* ── upload card ── */
        .upload-wrapper {
            width: 100%;
            max-width: 560px;
            animation: fadeUp .5s ease both;
        }

        .upload-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--blue-dim);
            border: 1px solid rgba(61,82,255,0.3);
            border-radius: 99px;
            padding: 5px 14px;
            font-size: clamp(0.68rem, 1.5vw, 0.75rem);
            color: #8b9bff;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        .upload-badge span { width: 6px; height: 6px; background: var(--blue); border-radius: 50%; flex-shrink: 0; }

        .upload-heading {
            font-family: 'Geist', sans-serif;
            font-size: clamp(1.5rem, 4vw, 2rem);
            font-weight: 800;
            letter-spacing: -0.02em;
            margin-bottom: 8px;
        }

        .upload-sub {
            font-size: clamp(0.82rem, 2vw, 0.9rem);
            color: var(--muted);
            margin-bottom: 32px;
            line-height: 1.6;
        }

        .upload-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: clamp(20px, 4vw, 36px);
        }

        /* ── drop zone ── */
        .drop-zone {
            border: 2px dashed var(--border);
            border-radius: 12px;
            padding: clamp(32px, 6vw, 48px) 24px;
            text-align: center;
            cursor: pointer;
            transition: border-color .2s, background .2s;
            position: relative;
            margin-bottom: 24px;
            /* touch-friendly tap target */
            -webkit-tap-highlight-color: transparent;
        }

        .drop-zone:hover,
        .drop-zone.dragover {
            border-color: var(--blue);
            background: var(--blue-dim);
        }

        .drop-zone input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
            height: 100%;
            /* Ensure it's tappable on iOS */
            font-size: 16px;
        }

        .drop-icon {
            width: clamp(42px, 8vw, 52px);
            height: clamp(42px, 8vw, 52px);
            background: var(--blue-dim);
            border: 1px solid rgba(61,82,255,0.25);
            border-radius: 12px;
            display: grid;
            place-items: center;
            margin: 0 auto 16px;
        }

        .drop-icon svg {
            width: clamp(20px, 4vw, 24px);
            height: clamp(20px, 4vw, 24px);
            stroke: var(--blue);
            fill: none;
            stroke-width: 1.8;
        }

        .drop-title {
            font-family: 'Geist', sans-serif;
            font-weight: 600;
            font-size: clamp(0.85rem, 2vw, 0.95rem);
            margin-bottom: 6px;
        }

        .drop-title span { color: var(--blue); }

        .drop-hint {
            font-size: clamp(0.73rem, 1.8vw, 0.8rem);
            color: var(--muted);
        }

        .file-selected {
            display: none;
            align-items: center;
            gap: 10px;
            background: var(--blue-dim);
            border: 1px solid rgba(61,82,255,0.3);
            border-radius: 8px;
            padding: 10px 14px;
            margin-top: 14px;
            font-size: clamp(0.76rem, 1.8vw, 0.825rem);
            color: #8b9bff;
        }

        .file-selected svg { width: 14px; height: 14px; stroke: var(--blue); fill: none; stroke-width: 2; flex-shrink: 0; }
        .file-selected.show { display: flex; }

        #fileName {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            min-width: 0;
        }

        /* ── submit button ── */
        .btn-upload {
            width: 100%;
            padding: clamp(12px, 2.5vw, 14px);
            background: var(--blue);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'Geist', sans-serif;
            font-size: clamp(0.875rem, 2vw, 0.95rem);
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: opacity .2s, transform .15s, box-shadow .2s;
            /* Touch-friendly min height */
            min-height: 48px;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
        }

        .btn-upload:hover  { opacity: 0.88; transform: translateY(-1px); box-shadow: 0 8px 28px var(--blue-glow); }
        .btn-upload:active { transform: translateY(0); opacity: 0.8; }
        .btn-upload svg { width: 16px; height: 16px; stroke: #fff; fill: none; stroke-width: 2; }

        /* Loading state */
        .btn-upload.loading {
            opacity: 0.7;
            cursor: not-allowed;
            pointer-events: none;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 20px;
            font-size: clamp(0.78rem, 1.8vw, 0.825rem);
            color: var(--muted);
            text-decoration: none;
            transition: color .2s;
            padding: 4px 0; /* slightly larger tap target */
        }

        .back-link:hover { color: var(--white); }
        .back-link svg { width: 13px; height: 13px; stroke: currentColor; fill: none; stroke-width: 2; }

        /* ── footer ── */
        footer {
            position: relative;
            z-index: 1;
            border-top: 1px solid var(--border);
            padding: clamp(16px, 2.5vw, 22px) clamp(16px, 4vw, 48px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: clamp(0.72rem, 1.5vw, 0.8rem);
            color: var(--muted);
            flex-wrap: wrap;
            gap: 12px;
        }

        footer a { color: var(--muted); text-decoration: none; transition: color .2s; }
        footer a:hover { color: var(--white); }
        .footer-right { display: flex; gap: clamp(14px, 3vw, 24px); align-items: center; }

        .footer-email {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* Hide email text on very small phones, keep icon */
        @media (max-width: 360px) {
            .footer-email-text { display: none; }
        }

        .footer-email svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 1.8; }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(18px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Tablet adjustments ── */
        @media (min-width: 641px) and (max-width: 1024px) {
            .upload-wrapper { max-width: 520px; }
        }

        /* ── Small mobile ── */
        @media (max-width: 400px) {
            .nav-logo span { display: none; }
            .upload-card { padding: 18px 16px; }
            .drop-zone { padding: 28px 16px; }
        }

        /* ── Landscape mobile ── */
        @media (max-height: 560px) and (orientation: landscape) {
            main { min-height: auto; padding: 24px clamp(16px, 4vw, 48px); }
            .drop-zone { padding: 20px 24px; }
            .drop-icon { margin-bottom: 10px; }
            .upload-sub { margin-bottom: 20px; }
        }
    </style>
</head>
<body>

    <!-- ── Upload Loading Overlay ── -->
    <div class="upload-overlay" id="uploadOverlay">
        <div class="spinner-ring">
            <svg viewBox="0 0 80 80">
                <circle class="spinner-track" cx="40" cy="40" r="30"/>
                <g class="spinner-rotate">
                    <circle class="spinner-arc" cx="40" cy="40" r="30"/>
                </g>
            </svg>
            <div class="spinner-inner">
                <svg viewBox="0 0 24 24">
                    <polyline points="16 16 12 12 8 16"/>
                    <line x1="12" y1="12" x2="12" y2="21"/>
                    <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
                </svg>
            </div>
        </div>
        <div class="upload-overlay-title">Uploading your file</div>
        <div class="upload-overlay-sub">Please wait a moment…</div>
        <div class="upload-dots">
            <span></span><span></span><span></span>
        </div>
    </div>

    <!-- ── Toast Notification ── -->
    <% if (locals.message) { %>
        <%
            const isError = locals.message.toLowerCase().includes('error') ||
                            locals.message.toLowerCase().includes('fail') ||
                            locals.message.toLowerCase().includes('invalid') ||
                            locals.message.toLowerCase().includes('not ');
            const toastType = isError ? 'error' : 'success';
        %>
        <div class="toast <%= toastType %>" id="toast">
            <div class="toast-icon">
                <% if (toastType === 'success') { %>
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                <% } else { %>
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                <% } %>
            </div>
            <%= locals.message %>
            <button class="toast-close" onclick="dismissToast()">
                <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
    <% } %>

    <nav>
        <a href="/" class="nav-logo">
            <div class="nav-logo-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 7c0-1.1.9-2 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/>
                </svg>
            </div>
            <span>FileVault</span>
        </a>
        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/upload" class="active">Upload</a></li>
            <li><a href="/download">Download</a></li>
        </ul>
        <a href="/upload" class="nav-cta">Get Started</a>
        <button class="nav-hamburger" id="hamburger" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
    </nav>

    <div class="nav-mobile-menu" id="mobileMenu">
        <a href="/">Home</a>
        <a href="/upload" class="active">Upload</a>
        <a href="/download">Download</a>
        <a href="/upload" class="nav-mobile-cta">Get Started</a>
    </div>

    <main>
        <div class="upload-wrapper">

            <div class="upload-badge"><span></span> Upload File</div>
            <h1 class="upload-heading">Choose your file</h1>
            <p class="upload-sub">Upload any file and receive a unique ID — use it anytime to retrieve your file.</p>

            <div class="upload-card">
                <form action="/upload" enctype="multipart/form-data" method="post" id="uploadForm">

                    <div class="drop-zone" id="dropZone">
                        <input type="file" name="file" id="fileInput">
                        <div class="drop-icon">
                            <svg viewBox="0 0 24 24"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                        </div>
                        <div class="drop-title"><span>Click to browse</span> or drag & drop</div>
                        <div class="drop-hint">Any file type supported</div>
                    </div>

                    <div class="file-selected" id="fileSelected">
                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        <span id="fileName">No file chosen</span>
                    </div>

                    <button type="submit" class="btn-upload" id="submitBtn" style="margin-top: 24px;">
