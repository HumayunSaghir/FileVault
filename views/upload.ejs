    <script>
        // ── Hamburger ──
        const hamburger  = document.getElementById('hamburger');
        const mobileMenu = document.getElementById('mobileMenu');
        hamburger.addEventListener('click', () => {
            hamburger.classList.toggle('open');
            mobileMenu.classList.toggle('open');
        });
        mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
            hamburger.classList.remove('open');
            mobileMenu.classList.remove('open');
        }));

        // ── Toast dismiss ──
        function dismissToast() {
            const toast = document.getElementById('toast');
            if (toast) {
                toast.style.animation = 'toastOut .35s ease forwards';
                setTimeout(() => toast.remove(), 350);
            }
        }

        const toast = document.getElementById('toast');
        if (toast) {
            setTimeout(() => toast.remove(), 4700);
        }

        // ── File input ──
        const dropZone    = document.getElementById('dropZone');
        const fileInput   = document.getElementById('fileInput');
        const fileSelected = document.getElementById('fileSelected');
        const fileName    = document.getElementById('fileName');
        const uploadForm  = document.getElementById('uploadForm');
        const submitBtn   = document.getElementById('submitBtn');
        const overlay     = document.getElementById('uploadOverlay');

        function showFile(name) {
            fileName.textContent = name;
            fileSelected.classList.add('show');
        }

        fileInput.addEventListener('change', () => {
            if (fileInput.files.length > 0) showFile(fileInput.files[0].name);
        });

        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('dragover');
        });

        dropZone.addEventListener('dragleave', (e) => {
            if (!dropZone.contains(e.relatedTarget)) {
                dropZone.classList.remove('dragover');
            }
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            if (e.dataTransfer.files.length > 0) {
                fileInput.files = e.dataTransfer.files;
                showFile(e.dataTransfer.files[0].name);
            }
        });

        // ── Upload loading overlay ──
        uploadForm.addEventListener('submit', (e) => {
            if (!fileInput.files || fileInput.files.length === 0) return; // let native validation handle

            // Show overlay
            overlay.classList.add('visible');
            submitBtn.classList.add('loading');

            // The form submits normally; server redirects to homepage after upload.
            // Fallback: if no redirect within 30s, hide overlay to avoid infinite lock.
            setTimeout(() => {
                overlay.classList.remove('visible');
                submitBtn.classList.remove('loading');
            }, 30000);
        });
    </script>

